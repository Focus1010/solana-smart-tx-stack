{
  "name": "solana-smart-tx-stack",
  "version": "2.0.0",
  "description": "Smart Solana transaction stack with Jito bundles, Yellowstone gRPC streaming, stream-based commitment tracking, leader window detection, and AI-driven tip and retry decisions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "run:stack": "ts-node src/index.ts",
    "run:inject": "ts-node src/scripts/fault-inject.ts",
    "run:marinade": "ts-node src/scripts/run-marinade.ts",
    "generate:evidence": "ts-node src/scripts/generate-evidence.ts",
    "generate:mainnet-report": "ts-node src/scripts/generate-mainnet-report.ts",
    "evidence:audit": "ts-node src/scripts/verify-evidence.ts",
    "verify:evidence": "ts-node src/scripts/verify-evidence.ts",
    "bounty:audit": "npm run generate:evidence && npm run evidence:audit",
    "test": "ts-node test/unit.test.ts && ts-node test/rate-limiter.test.ts && ts-node test/blockhash-cache.test.ts",
    "test:unit": "ts-node test/unit.test.ts",
    "test:rate-limiter": "ts-node test/rate-limiter.test.ts",
    "test:blockhash-cache": "ts-node test/blockhash-cache.test.ts",
    "challenge:doctor": "ts-node src/scripts/doctor.ts",
    "challenge:run": "ts-node src/index.ts",
    "challenge:reset-evidence": "node -e \"const fs=require('fs'); fs.writeFileSync('logs/lifecycle.json','[]'); console.log('lifecycle.json reset');\"",
    "challenge:export-evidence": "npm run generate:evidence",
    "challenge:verify-evidence": "npm run verify:evidence"
  },
  "keywords": [
    "solana",
    "jito",
    "yellowstone",
    "bundles",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@solana/web3.js": "^1.98.4",
    "@triton-one/yellowstone-grpc": "^5.0.8",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.2.1",
    "jito-js-rpc": "^0.2.2",
    "jito-ts": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
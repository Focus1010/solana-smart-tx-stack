# ─── Required ─────────────────────────────────────────────────────────────────

# Your Groq API key - get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
AI_PROVIDER=groq
# ANTHROPIC_API_KEY=    (optional, only needed if AI_PROVIDER=anthropic)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Your Solana wallet private key - base58 encoded (Phantom export format)
# On devnet this wallet will be auto-airdropped if balance is low
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ─── Network ──────────────────────────────────────────────────────────────────

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# ─── Jito ─────────────────────────────────────────────────────────────────────

# IMPORTANT: Jito does NOT operate a block engine on Solana devnet.
# For devnet runs, bundle submissions will always be rejected with BUNDLE_DROPPED.
# This is expected -- the stack logs it and continues. Devnet runs still produce
# real confirmed transactions and real lifecycle logs via sendAndConfirmTransaction.
#
# For actual bundle landing you have two options:
#   1. Use the Jito testnet block engine (Solana testnet, not devnet):
#      JITO_RPC_URL=https://dallas.testnet.block-engine.jito.wtf/api/v1
#   2. Use mainnet:
#      JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1
#
# Available mainnet regional endpoints:
#   https://mainnet.block-engine.jito.wtf/api/v1        (global)
#   https://amsterdam.mainnet.block-engine.jito.wtf/api/v1
#   https://frankfurt.mainnet.block-engine.jito.wtf/api/v1
#   https://ny.mainnet.block-engine.jito.wtf/api/v1
#   https://tokyo.mainnet.block-engine.jito.wtf/api/v1
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1

# ─── Yellowstone gRPC (optional) ──────────────────────────────────────────────
# Leave blank to use the RPC polling fallback - perfectly fine for devnet.
# If you have SolInfra credits, fill these in for real gRPC streaming.

YELLOWSTONE_ENDPOINT=
YELLOWSTONE_TOKEN=

# ─── Groq model ───────────────────────────────────────────────────────────────

# llama3-70b-8192 is the recommended model - fast, free tier, good reasoning
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Stack behaviour ──────────────────────────────────────────────────────────

MAX_RETRIES=3
RETRY_DELAY_MS=2000
BUNDLE_COUNT=10
LOG_DIR=./logs

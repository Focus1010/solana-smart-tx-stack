# ─── Required ──────────────────────────────────────────────────────────────

# Your Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Your Solana wallet private key — base58 encoded (Phantom export format)
# On devnet this wallet will be auto-airdropped if balance is low
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ─── Network ───────────────────────────────────────────────────────────────

# Set to 'devnet' or 'mainnet-beta'
SOLANA_NETWORK=devnet

# Network-specific RPC endpoints (optional — will use defaults based on SOLANA_NETWORK)
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WS_URL=wss://api.devnet.solana.com

# ─── Jito ──────────────────────────────────────────────────────────────────

# Jito endpoints are automatically set based on SOLANA_NETWORK.
# Devnet: https://devnet.block-engine.jito.wtf
# Mainnet: https://mainnet.block-engine.jito.wtf
# Override below if needed:
# JITO_BLOCK_ENGINE_URL=
# JITO_RPC_URL=

# ─── Yellowstone gRPC (optional) ────────────────────────────────────────────
# Leave blank to use the RPC polling fallback — perfectly fine for devnet.
# If you have SolInfra credits, fill these in for real gRPC streaming.

YELLOWSTONE_ENDPOINT=
YELLOWSTONE_TOKEN=

# ─── Groq model ─────────────────────────────────────────────────────────────

# llama3-70b-8192 is the recommended model — fast, free tier, good reasoning
GROQ_MODEL=llama3-70b-8192

# ─── Stack behaviour ────────────────────────────────────────────────────────

MAX_RETRIES=3
RETRY_DELAY_MS=2000
BUNDLE_COUNT=10
LOG_DIR=./logs
